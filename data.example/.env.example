# API keys and other environment variables for the container.
# Copy this file to .env and override with your own values.

# Create a restrictive token, consider something like:
# Read: content, issues, and metadata. Read/Write: pull requests
GH_TOKEN=secret

# Git identity (replaces mounting ~/.gitconfig into the container)
GIT_CONFIG_COUNT=2
GIT_CONFIG_KEY_0=user.name
GIT_CONFIG_VALUE_0=Your Name
GIT_CONFIG_KEY_1=user.email
GIT_CONFIG_VALUE_1=your.email@example.com
